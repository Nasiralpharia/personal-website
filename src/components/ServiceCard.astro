---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<article class="service-card">
  <h3>{title}</h3>
  <p><slot /></p>
</article>

<style>
  .service-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem;
  }
  .service-card h3 { margin-bottom: 0.5rem; }
  .service-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
